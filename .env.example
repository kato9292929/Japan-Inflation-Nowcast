# Japan Inflation Nowcast — 環境変数テンプレート（§10）
# このファイルをコピーして .env を作る。.env は絶対にコミットしない（.gitignore 済み）。

# --- Database ---
# 本番は Postgres。ローカル検証は SQLite 可。
# 例: postgresql+psycopg://user:pass@localhost:5432/jin
# 例: sqlite:///./jin.db
DATABASE_URL=sqlite:///./jin.db

# --- x402 課金（USDC on Base）---
# 既存の facilitator / Oracle 経路を再利用する前提。
X402_FACILITATOR_URL=
X402_RECIPIENT_ADDRESS=
X402_CHAIN=base
X402_ASSET=usdc

# --- スクレイパ（§8 遵守機構）---
# User-Agent と問い合わせ先は必ず明示する。
SCRAPER_USER_AGENT=JapanInflationNowcastBot/0.1
SCRAPER_CONTACT=ops@example.com

# --- 指数の基準期 / リベース方針 ---
# BASE_DATE は ISO 日付（基準期の代表日）。
BASE_DATE=2025-01-01
# REBASE_POLICY: annual | manual
REBASE_POLICY=annual
